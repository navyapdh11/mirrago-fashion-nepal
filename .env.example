APP_NAME="Mirrago Fashion Nepal"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Kathmandu
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=/data/data/com.termux/files/home/app/database/database.sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=mirrago_fashion
# DB_USERNAME=root
# DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@mirragofashion.com.np"
MAIL_FROM_NAME="${APP_NAME}"

# eSewa Payment Gateway
ESEWA_MERCHANT_ID=your_esewa_merchant_id
ESEWA_SECRET_KEY=your_esewa_secret_key
ESEWA_API_URL=https://rc-epay.esewa.com.np/api/epay/main/v2/form
ESEWA_VERIFY_URL=https://rc-epay.esewa.com.np/api/epay/transaction/details/
ESEWA_SUCCESS_URL=${APP_URL}/payment/success
ESEWA_FAILURE_URL=${APP_URL}/payment/failed

# Khalti Payment Gateway
KHALTI_PUBLIC_KEY=your_khalti_public_key
KHALTI_SECRET_KEY=your_khalti_secret_key
KHALTI_API_URL=https://a.khalti.com/api/v2/epayment
KHALTI_WEBHOOK_SECRET=your_khalti_webhook_secret
KHALTI_RETURN_URL=${APP_URL}/payment/khalti/callback

# Mirrago AI Virtual Try-On
MIRRAGO_API_KEY=your_mirrago_api_key
MIRRAGO_BASE_URL=https://api.mirrago.com/v1
MIRRAGO_WEBHOOK_SECRET=your_mirrago_webhook_secret

# Pusher (Real-time Inventory Updates)
PUSHER_APP_ID=your_pusher_app_id
PUSHER_APP_KEY=your_pusher_app_key
PUSHER_APP_SECRET=your_pusher_app_secret
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# AI Recommendations
AI_RECOMMENDATION_CACHE_TTL=3600
AI_MODEL_API_KEY=your_ai_model_api_key
